{
  // Editor
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'JetBrainsMono NF', Consolas, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.largeFileOptimizations": false,
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "modificationsIfAvailable",
  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.showToolbar": "always",
  "terminal.integrated.fontFamily": "'JetBrainsMono NF', Consolas, 'Courier New', monospace",
  "files.insertFinalNewline": true,
  "files.autoSave": "afterDelay",
  "workbench.colorTheme": "Dark 2026",
  "workbench.editor.empty.hint": "hidden",

  // Window
  "window.title": "${rootName} - ${activeEditorShort}",

  // Go
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": { "source.organizeImports": "explicit" }
  },
  "go.useLanguageServer": true,
  "go.lintTool": "golangci-lint",
  "go.lintOnSave": "workspace",
  "gopls": {
    "ui.semanticTokens": true
  },

  // HTML
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },

  // Helm
  "[helm]": {
    "editor.formatOnSave": false
  },

  // Java
  "[java]": {
    "editor.defaultFormatter": "redhat.java",
    "editor.formatOnSave": true
  },
  "java.format.settings.url": ".vscode/java-formatter.xml",
  "java.configuration.updateBuildConfiguration": "automatic",

  // JavaScript / TypeScript
  "[javascript][typescript]": {
    "updateImportsOnFileMove.enabled": "always",
  },

  // JSON
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },

  // JSONC
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },

  // Markdown
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },

  // Nix
  "[nix]": {
    "editor.defaultFormatter": "NixOS.nixfmt"
  },
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverArguments": ["--semantic-tokens=true"],
  "nix.formatterPath": "nixfmt",
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": ["nixfmt"]
      }
    }
  },
  "NixOS.nixfmt/bin": "nixfmt",

  // Python
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnType": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },

  // YAML
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "yaml.disableSchemaDetection": [
    "**/.github/workflows/*.yml",
    "**/.github/workflows/*.yaml",
    "**/.gitea/workflows/*.yml",
    "**/.gitea/workflows/*.yaml",
    "**/.forgejo/workflows/*.yml",
    "**/.forgejo/workflows/*.yaml"
  ],

  // Extensions
  "ansible.lightspeed.enabled": false,
  "claudeCode.preferredLocation": "panel",
  "cSpell.enabled": false,
  "errorLens.enabled": true,
  "errorLens.enabledDiagnosticLevels": [
    "error",
    "warning",
    "hint",
    "info"
  ],
  "errorLens.delay": 1000,
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "sql": true
  },
  "git.confirmSync": false,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://developer.microsoft.com/json-schemas/": true,
    "https://biomejs.dev": true
  },
  "typescript.": "always",
  "vs-kubernetes": {
    "vs-kubernetes.crd-code-completion": "enabled"
  },

  // Telemetry
  "telemetry.telemetryLevel": "off",
  "redhat.telemetry.enabled": false,
  "github.copilot.advanced": {
    "telemetry.enabled": false
  },
  "security.workspace.trust.trustedFolders": [
    "/home/tobi/Repos"
  ],
}
