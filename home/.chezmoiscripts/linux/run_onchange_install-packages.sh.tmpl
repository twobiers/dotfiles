{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# Machine package reconciler — generated by chezmoi. Do not edit directly.
# packages.yaml: {{ include (printf "%s/.chezmoidata/packages.yaml" .chezmoi.sourceDir) | sha256sum }}
# profiles: {{ range $key, $value := .profiles }}{{ if $value }}{{ $key }} {{ end }}{{ end }}

set -euo pipefail

{{- $profiles := list }}
{{- range $key, $value := .profiles }}
  {{- if $value }}
    {{- $profiles = append $profiles $key }}
  {{- end }}
{{- end }}

{{- /* ── Collect desired state across active profiles ─────────────────────── */}}
{{- $desiredPkgs  := list }}
{{- $desiredPPAs  := list }}
{{- $desiredRepos := list }}
{{- $condRules    := list }}
{{- range $profiles }}
  {{- $p := . }}
  {{- if hasKey $.packages.profiles $p }}
    {{- $profData := index $.packages.profiles $p }}
    {{- if hasKey $profData "apt" }}
      {{- $apt := $profData.apt }}
      {{- if hasKey $apt "packages" }}
        {{- $desiredPkgs = concat $desiredPkgs $apt.packages }}
      {{- end }}
      {{- if hasKey $apt "sources" }}
        {{- if hasKey $apt.sources "ppas" }}
          {{- $desiredPPAs = concat $desiredPPAs $apt.sources.ppas }}
        {{- end }}
        {{- if hasKey $apt.sources "repos" }}
          {{- $desiredRepos = concat $desiredRepos $apt.sources.repos }}
        {{- end }}
      {{- end }}
      {{- if hasKey $apt "conditional_packages" }}
        {{- $condRules = concat $condRules $apt.conditional_packages }}
      {{- end }}
    {{- end }}
  {{- end }}
{{- end }}

{{- /* Deduplicate repos by id */}}
{{- $_ := "" }}
{{- $uniqueRepos := list }}
{{- $seenRepoIDs := dict }}
{{- range $desiredRepos }}
  {{- if not (hasKey $seenRepoIDs .id) }}
    {{- $_ = set $seenRepoIDs .id "1" }}
    {{- $uniqueRepos = append $uniqueRepos . }}
  {{- end }}
{{- end }}

STATE_DIR="$HOME/.local/state/machine-setup"
mkdir -p "$STATE_DIR"

STATE_PKGS="$STATE_DIR/packages"
STATE_PPAS="$STATE_DIR/ppas"
STATE_REPOS="$STATE_DIR/repos"

touch "$STATE_PKGS" "$STATE_PPAS" "$STATE_REPOS"

# shellcheck disable=SC1091
source "${CHEZMOI_SOURCE_DIR}/../lib/lib.sh"

log::info "Active profiles: {{ $profiles | join ", " }}"

# ── Desired base packages ────────────────────────────────────────────────────
DESIRED_PKGS=({{ range $desiredPkgs | uniq }}{{ . | quote }} {{ end }})

# ── Desired PPAs ─────────────────────────────────────────────────────────────
DESIRED_PPAS=({{ range $desiredPPAs | uniq }}{{ . | quote }} {{ end }})

# ── Desired repos ────────────────────────────────────────────────────────────
declare -A REPO_URL REPO_KEY_URL REPO_SUITES REPO_COMPONENTS
{{ range $uniqueRepos -}}
REPO_URL[{{ .id | quote }}]={{ .url | quote }}
REPO_KEY_URL[{{ .id | quote }}]={{ .key_url | quote }}
REPO_SUITES[{{ .id | quote }}]={{ .suites | join " " | quote }}
REPO_COMPONENTS[{{ .id | quote }}]={{ .components | join " " | quote }}
{{ end -}}
DESIRED_REPOS=({{ range $uniqueRepos }}{{ .id | quote }} {{ end }})

# ── Conditional packages (evaluated at runtime) ───────────────────────────────
resolve_conditionals() {
  local -a extra=()
{{ range $condRules -}}
  for w in {{ range .when.any_installed }}{{ . | quote }} {{ end }}; do
    if dpkg-query -W -f='${Status}' "$w" 2>/dev/null | grep -q "install ok installed"; then
      extra+=({{ range .packages }}{{ . | quote }} {{ end }})
      break
    fi
  done
{{ end -}}
  printf '%s\n' ${extra[@]+"${extra[@]}"}
}

# ── Build full desired package list (base + conditionals) ─────────────────────
mapfile -t ALL_DESIRED_PKGS < <(
  { printf '%s\n' ${DESIRED_PKGS[@]+"${DESIRED_PKGS[@]}"}
    resolve_conditionals; } | sort -u
)

APT_NEEDS_UPDATE=false

# ── Reconcile PPAs ────────────────────────────────────────────────────────────
while IFS= read -r ppa; do
  [[ -z "$ppa" ]] && continue
  log::info "Removing PPA: $ppa"
  sudo add-apt-repository --remove -y "ppa:$ppa" || true
  APT_NEEDS_UPDATE=true
done < <(comm -23 <(sort "$STATE_PPAS") <(printf '%s\n' ${DESIRED_PPAS[@]+"${DESIRED_PPAS[@]}"} | sort))

while IFS= read -r ppa; do
  [[ -z "$ppa" ]] && continue
  log::info "Adding PPA: $ppa"
  sudo add-apt-repository -y "ppa:$ppa"
  APT_NEEDS_UPDATE=true
done < <(comm -13 <(sort "$STATE_PPAS") <(printf '%s\n' ${DESIRED_PPAS[@]+"${DESIRED_PPAS[@]}"} | sort))

# ── Reconcile repos ───────────────────────────────────────────────────────────
while IFS= read -r repo_id; do
  [[ -z "$repo_id" ]] && continue
  log::info "Removing repo: $repo_id"
  sudo rm -f "/etc/apt/sources.list.d/${repo_id}.list"
  sudo rm -f "/etc/apt/keyrings/${repo_id}.gpg"
  APT_NEEDS_UPDATE=true
done < <(comm -23 <(sort "$STATE_REPOS") <(printf '%s\n' ${DESIRED_REPOS[@]+"${DESIRED_REPOS[@]}"} | sort))

while IFS= read -r repo_id; do
  [[ -z "$repo_id" ]] && continue
  log::info "Adding repo: $repo_id"
  sudo mkdir -p /etc/apt/keyrings
  curl -fsSL "${REPO_KEY_URL[$repo_id]}" | sudo gpg --dearmor -o "/etc/apt/keyrings/${repo_id}.gpg"
  printf 'deb [signed-by=/etc/apt/keyrings/%s.gpg] %s %s %s\n' \
    "$repo_id" "${REPO_URL[$repo_id]}" "${REPO_SUITES[$repo_id]}" "${REPO_COMPONENTS[$repo_id]}" \
    | sudo tee "/etc/apt/sources.list.d/${repo_id}.list" > /dev/null
  APT_NEEDS_UPDATE=true
done < <(comm -13 <(sort "$STATE_REPOS") <(printf '%s\n' ${DESIRED_REPOS[@]+"${DESIRED_REPOS[@]}"} | sort))

# ── Reconcile packages ────────────────────────────────────────────────────────
mapfile -t TO_REMOVE < <(
  comm -23 <(sort "$STATE_PKGS") <(printf '%s\n' ${ALL_DESIRED_PKGS[@]+"${ALL_DESIRED_PKGS[@]}"} | sort)
)

mapfile -t TO_INSTALL < <(
  for pkg in ${ALL_DESIRED_PKGS[@]+"${ALL_DESIRED_PKGS[@]}"}; do
    dpkg-query -W -f='${Status}' "$pkg" 2>/dev/null | grep -q "install ok installed" || echo "$pkg"
  done
)

if [[ ${#TO_REMOVE[@]} -gt 0 ]]; then
  log::info "Removing packages: ${TO_REMOVE[*]}"
  sudo apt-get remove -y "${TO_REMOVE[@]}"
fi

if [[ ${#TO_INSTALL[@]} -gt 0 || "$APT_NEEDS_UPDATE" == "true" ]]; then
  sudo apt-get update
fi

if [[ ${#TO_INSTALL[@]} -gt 0 ]]; then
  log::info "Installing packages: ${TO_INSTALL[*]}"
  sudo apt-get install -y --no-install-recommends "${TO_INSTALL[@]}"
fi

# ── Write new state ───────────────────────────────────────────────────────────
printf '%s\n' ${ALL_DESIRED_PKGS[@]+"${ALL_DESIRED_PKGS[@]}"} | sort -u > "$STATE_PKGS"
printf '%s\n' ${DESIRED_PPAS[@]+"${DESIRED_PPAS[@]}"} | sort -u > "$STATE_PPAS"
printf '%s\n' ${DESIRED_REPOS[@]+"${DESIRED_REPOS[@]}"} | sort -u > "$STATE_REPOS"

log::info "Done. State written to $STATE_DIR/"
{{ end -}}
